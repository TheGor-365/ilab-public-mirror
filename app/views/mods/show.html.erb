<% provide :page_title, (@mod.try(:name) || "Mod ##{@mod.id}") %>
<% currently_at 'iPhone Modules' %>

<% if turbo_frame_request? %>
  <%= turbo_frame_tag turbo_frame_request_id do %>
    <%= render partial: "details", locals: { mod: @mod } %>
  <% end %>
<% else %>
  <div class="container py-3">
    <div class="d-flex align-items-center gap-3 mb-3">
      <%= link_to "← К списку модулей", mods_path, class: "btn btn-link p-0" %>
      <%= link_to "← В магазин", store_path, class: "btn btn-link p-0" %>
    </div>
    <%= render partial: "details", locals: { mod: @mod } %>
  </div>
<% end %>
