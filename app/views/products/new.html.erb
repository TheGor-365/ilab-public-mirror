<% provide :page_title, "Выставить товар на продажу" %>

<div class="page-banner">
  <div class="container page-banner__inner">
    <div class="page-banner__title">
      <i class="bi bi-plus-square"></i> Выставить товар на продажу
    </div>
    <div class="d-flex gap-2">
      <%= link_to products_path, class: "btn btn-sm btn-outline-secondary", title: "Каталог" do %>
        <i class="bi bi-card-list"></i><span class="d-none d-sm-inline ms-1">Каталог</span>
      <% end %>
      <%# убрал большую «Выставить на продажу»: мы уже на этой странице %>
    </div>
  </div>
</div>
<div class="page-banner-spacer"></div>

<h3 class="mb-3">Новый товар</h3>
<%= render "form" %>

<div class="page-bottom-spacer"></div>
