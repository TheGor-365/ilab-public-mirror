<% provide :page_title, "Редактирование товара" %>

<div class="page-banner">
  <div class="container page-banner__inner">
    <div class="page-banner__title">
      <i class="bi bi-pencil-square"></i> Редактировать товар
    </div>
    <div class="d-flex gap-2">
      <%= link_to "Выставить на продажу", new_product_path, class: "btn btn-sm btn-success" %>
      <%= link_to "Список товаров", products_path, class: "btn btn-sm btn-outline-secondary" %>
    </div>
  </div>
</div>
<div class="page-banner-spacer"></div>

<div class="container py-4">
  <h3 class="mb-3">Редактировать товар</h3>
  <%= render "products/form" %>
</div>
